  "drawer_support": {
    "key": "drawer_support",
    "name": "Drawer dividers",
    "dimensions": {
      "width": "dim_w - 2 * ply_carcass",
      "height": "dim_drawer_divider",
      "thickness": "ply_drawer_divider"
    },
    "quantity": "num_drawers * 2",
    "viz3d": {
      "color": 13808780,
      "orientation": "horizontal",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass",
          "y": "i * (drawer_height + ply_drawer_divider)",
          "z": "0"
        },
        {
          "x": "ply_carcass",
          "y": "i * (drawer_height + ply_drawer_divider)",
          "z": "dim_d - dim_drawer_divider - ply_carcass_back"
        }
      ]
    }
  },
  "drawer_sides": {
    "key": "drawer_sides",
    "name": "Drawer sides",
    "dimensions": {
      "width": "drawer_depth",
      "height": "drawer_height - ply_bottom - 2 * drawer_clearance",
      "thickness": "ply_drawer"
    },
    "quantity": "2 * num_drawers",
    "viz3d": {
      "color": 16113331,
      "orientation": "rotated",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass + dim_slides_w",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + ply_bottom + drawer_clearance",
          "z": "ply_drawer_face"
        },
        {
          "x": "dim_w - ply_carcass - dim_slides_w - ply_drawer",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + ply_bottom + drawer_clearance",
          "z": "ply_drawer_face"
        }
      ]
    }
  },
  "drawer_front_back": {
    "key": "drawer_front_back",
    "name": "Drawer front/back",
    "dimensions": {
      "width": "drawer_width - 2 * ply_drawer",
      "height": "drawer_height - ply_bottom - 2 * drawer_clearance",
      "thickness": "ply_drawer"
    },
    "quantity": "2 * num_drawers",
    "viz3d": {
      "color": 16115411,
      "orientation": "vertical",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass + dim_slides_w + ply_drawer",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + ply_bottom + drawer_clearance",
          "z": "ply_drawer_face"
        },
        {
          "x": "ply_carcass + dim_slides_w + ply_drawer",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + ply_bottom + drawer_clearance",
          "z": "ply_drawer_face + drawer_depth - ply_drawer"
        }
      ]
    }
  },
  "drawer_bottom": {
    "key": "drawer_bottom",
    "name": "Drawer bottom",
    "dimensions": {
      "width": "drawer_width",
      "height": "drawer_depth",
      "thickness": "ply_bottom"
    },
    "quantity": "num_drawers",
    "viz3d": {
      "color": 15128515,
      "orientation": "horizontal",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass + dim_slides_w",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + drawer_clearance",
          "z": "ply_drawer_face"
        }
      ]
    }
  },
  "drawer_face": {
    "key": "drawer_face",
    "name": "Drawer faces",
    "dimensions": {
      "width": "dim_w - 2 * ply_carcass - 2 * drawer_clearance",
      "height": "drawer_height - 2 * drawer_clearance",
      "thickness": "ply_drawer_face"
    },
    "quantity": "num_drawers",
    "viz3d": {
      "color": 9127187,
      "orientation": "vertical",
      "condition": "drawer_face_enabled && ply_drawer_face > 0",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass + drawer_clearance",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + drawer_clearance",
          "z": "0"
        }
      ]
    }
  },
  "drawer_slides": {
    "key": "drawer_slides",
    "name": "Drawer slides",
    "dimensions": {
      "width": "dim_slides_w",
      "height": "2.0",
      "thickness": "ply_carcass"
    },
    "quantity": "2 * num_drawers",
    "viz3d": {
      "color": 12632256,
      "orientation": "horizontal",
      "loop": "num_drawers",
      "instances": [
        {
          "x": "ply_carcass",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + 1.0",
          "z": "ply_drawer_face"
        },
        {
          "x": "dim_w - ply_carcass - dim_slides_w",
          "y": "i * (drawer_height + ply_drawer_divider) + ply_drawer_divider + 1.0",
          "z": "ply_drawer_face"
        }
      ]
    }
  }
