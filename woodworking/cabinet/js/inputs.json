{
  "sections": [
    {
      "title": "Cabinet Dimensions",
      "inputs": [
        {
          "variable_id": "dim_w",
          "step": 0.125,
          "layout": "row3"
        },
        {
          "variable_id": "dim_h",
          "step": 0.125,
          "layout": "row3"
        },
        {
          "variable_id": "dim_d",
          "step": 0.125,
          "layout": "row3"
        },
        {
          "variable_id": "dim_drawer_support",
          "step": 0.125,
          "layout": "row2"
        },
        {
          "variable_id": "dim_back_stretcher",
          "step": 0.125,
          "layout": "row2",
          "condition": "backing_style === 'stretcher'"
        },
        {
          "variable_id": "dim_railing_w",
          "step": 0.125
        },
        {
          "variable_id": "num_drawers",
          "min": 1,
          "max": 10,
          "step": 1,
          "layout": "row2"
        },
        {
          "variable_id": "drawer_clearance",
          "step": 0.0625,
          "layout": "row2"
        }
      ]
    },
    {
      "title": "Cabinet Style",
      "inputs": [
        {
          "variable_id": "backing_style",
          "type": "select",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "stretcher", "label": "Stretcher Only" },
            { "value": "inlay", "label": "Routed Inlay" },
            { "value": "full", "label": "Full Plywood" }
          ]
        }
      ]
    },
    {
      "title": "Plywood Materials",
      "type": "plywood_table",
      "initial_state": {
        "full": [
          {"thickness": 0.75, "components": ["carcass_sides", "carcass_top", "drawer_stretcher"]},
          {"thickness": 0.5, "components": ["drawer_sides", "carcass_back"]},
          {"thickness": 0.25, "components": ["drawer_bottom"]},
          {"thickness": 0, "components": ["drawer_face"]}
        ],
        "inlay": [
          {"thickness": 0.75, "components": ["carcass_sides", "carcass_top", "drawer_stretcher"]},
          {"thickness": 0.5, "components": ["drawer_sides"]},
          {"thickness": 0.25, "components": ["drawer_bottom", "carcass_back"]},
          {"thickness": 0, "components": ["drawer_face"]}
        ],
        "stretcher": [
          {"thickness": 0.75, "components": ["carcass_sides", "carcass_top", "drawer_stretcher", "back_stretcher"]},
          {"thickness": 0.5, "components": ["drawer_sides"]},
          {"thickness": 0.25, "components": ["drawer_bottom"]},
          {"thickness": 0, "components": ["drawer_face"]}
        ],
        "none": [
          {"thickness": 0.75, "components": ["carcass_sides", "carcass_top", "drawer_stretcher"]},
          {"thickness": 0.5, "components": ["drawer_sides"]},
          {"thickness": 0.25, "components": ["drawer_bottom"]},
          {"thickness": 0, "components": ["drawer_face"]}
        ]
      }
    },
    {
      "title": "Cut Settings",
      "inputs": [
        {
          "variable_id": "sheet_w",
          "step": 1
        },
        {
          "variable_id": "sheet_h",
          "step": 1
        },
        {
          "variable_id": "kerf",
          "step": 0.0625
        }
      ]
    }
  ]
}
